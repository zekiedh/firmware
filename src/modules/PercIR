#include <Arduino.h>
#include "driver/rmt.h" // The ESP32 hardware peripheral for microsecond precision

// --- HARDWARE SETTINGS ---
// GPIO 4 is the standard IR pin for the T-Embed CC1101.
// If using Bruce, you can replace this with: (gpio_num_t)HAL::getIrTxPin()
#define IR_TX_PIN GPIO_NUM_4  
#define RMT_TX_CHANNEL RMT_CHANNEL_0

// Set clock to 1MHz (1 tick = 1 microsecond)
#define RMT_CLK_DIV 80 

// --- PRICER PROTOCOL TIMINGS (MICROSECONDS) ---
// These pulse lengths are what the Electronic Shelf Labels are looking for.
#define PULSE_HIGH_US 2   // The length of the "ON" flash
#define ZERO_LOW_US   4   // The "OFF" duration for a binary 0
#define ONE_LOW_US    8   // The "OFF" duration for a binary 1

/**
 * Initializes the RMT hardware for raw, high-speed IR transmission.
 */
void setup_precir_rmt() {
    rmt_config_t config = RMT_DEFAULT_CONFIG_TX(IR_TX_PIN, RMT_TX_CHANNEL);
    
    // IMPORTANT: Disable the 38kHz carrier used by TV remotes. 
    // Pricer tags need raw, high-frequency optical pulses.
    config.tx_config.carrier_en = false; 
    config.clk_div = RMT_CLK_DIV;
    
    ESP_ERROR_CHECK(rmt_config(&config));
    ESP_ERROR_CHECK(rmt_driver_install(config.channel, 0, 0));
}

/**
 * Converts a byte array (image data) into hardware-timed pulses and fires the LED.
 */
void blast_payload(const uint8_t* payload, size_t len) {
    size_t num_items = len * 8;
    rmt_item32_t* items = (rmt_item32_t*) malloc(num_items * sizeof(rmt_item32_t));
    
    if (!items) return; // Fail-safe if RAM is full

    size_t item_idx = 0;
    
    for (size_t i = 0; i < len; i++) {
        uint8_t current_byte = payload[i];
        
        // Process bits from Most Significant to Least Significant
        for (int bit = 7; bit >= 0; bit--) {
            bool is_one = (current_byte & (1 << bit)) != 0;
            
            // Pulse ON
            items[item_idx].duration0 = PULSE_HIGH_US;
            items[item_idx].level0 = 1; 
            
            // Pulse OFF (Duration depends on if bit is 0 or 1)
            items[item_idx].duration1 = is_one ? ONE_LOW_US : ZERO_LOW_US;
            items[item_idx].level1 = 0;
            
            item_idx++;
        }
    }

    // Hand the data to the DMA hardware to blast it at bare-metal speeds
    rmt_write_items(RMT_TX_CHANNEL, items, num_items, true);
    
    // Wait until the physical light pulses are finished
    rmt_wait_tx_done(RMT_TX_CHANNEL, portMAX_DELAY);
    
    free(items); // Clean up RAM
}

void setup() {
    Serial.begin(115200);
    setup_precir_rmt();
    Serial.println("PrecIR Engine Active.");
}

void loop() {
    // A placeholder hex payload (you'll generate real image hex using TagTinker tools)
    uint8_t test_packet[] = { 0x41, 0x42, 0x43, 0x44 }; 
    
    Serial.println("Blasting IR...");
    blast_payload(test_packet, sizeof(test_packet));
    
    delay(5000); // Wait 5 seconds between bursts
}
